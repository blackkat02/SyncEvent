{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Node",
    "lib": ["ESNext", "DOM"],

    "strict": true,

    "declaration": true,
    "declarationMap": true,
    "composite": true,

    "rootDir": "src",
    "outDir": "dist",

    "baseUrl": ".",

    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src"]
}