# ==============================
# Application
# ==============================

NODE_ENV=development
PORT=3000

# ==============================
# Database (PostgreSQL / Prisma)
# ==============================

# Local development
DATABASE_URL=postgresql://user:password@localhost:5432/syncevent_db?schema=public

# If using Docker Compose the host will be the service name:
# DATABASE_URL=postgresql://user:password@postgres:5432/syncevent_db?schema=public

POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=syncevent_db

# ==============================
# Authentication (JWT)
# ==============================

JWT_SECRET=change_this_secret_in_production
JWT_EXPIRES_IN=24h

# ==============================
# pgAdmin (optional for Docker)
# ==============================

PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=admin